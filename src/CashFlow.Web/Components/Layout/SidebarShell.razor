@rendermode CashFlow.Web.AppRenderModes.Interactive
@using CashFlow.Web.Services

<div class="sidebar">
    <div class="top-row ps-3 navbar navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="">CashFlow</a>
        </div>
    </div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <div class="sidebar-menu">
        <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
            <nav class="flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Fluxo de Caixa
                    </NavLink>
                </div>
            </nav>
        </div>
    </div>

    <div class="sidebar-footer px-3 pb-3">
        <button type="button" class="sidebar-logout" @onclick="LogoutAsync">
            Sair
        </button>
    </div>
</div>

@code {
    [Inject] protected AuthSession Session { get; set; } = default!;
    [Inject] protected NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.EnsureRestoredAsync();
        }
    }

    protected async Task LogoutAsync()
    {
        await Session.ClearAsync();
        Navigation.NavigateTo("/login", replace: true);
    }
}
